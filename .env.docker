# Docker container path overrides — loaded after .env in docker-compose
DATA_ROOT=/data
DATA_DB_PATH=/data/web-agent.db


# ── Mode ──────────────────────────────────────────────────────────

# Production mode — enables frontend static file serving (default: false)
PROD=true

# Enforce JWT authentication (default: false)
ENFORCE_AUTH=true

# ── Container ─────────────────────────────────────────────────────

# Enable per-user Docker container isolation (default: false)
CONTAINER_MODE=true

# Idle timeout before stopping a container, in seconds (default: 1800 = 30 min)
CONTAINER_IDLE_TTL=1800