# Docker container path overrides — loaded after .env in docker-compose
DATA_ROOT=/data
DATA_DB_PATH=/data/web-agent.db
LOG_DIR=/app/logs

# ── Host Path Mapping ──────────────────────────────────────────────
#
# Absolute path to the data directory on the Docker HOST machine.
# Needed for container mode volume mounts: Docker resolves volume
# source paths on the HOST, not inside the main_server container.
#
# For docker-compose deployment, set this to the actual host path:
#   HOST_DATA_ROOT=/home/ubuntu/web-agent/data
#
# For local dev (main_server on host): leave unset — defaults to
# DATA_ROOT.resolve(), which is already the correct host path.
#
# HOST_DATA_ROOT=/home/ubuntu/web-agent/data

# ── Mode ──────────────────────────────────────────────────────────

# Production mode — enables frontend static file serving (default: false)
PROD=true

# Enforce JWT authentication (default: false)
ENFORCE_AUTH=true

# ── Container ─────────────────────────────────────────────────────

# Enable per-user Docker container isolation (default: false)
CONTAINER_MODE=true

# Idle timeout before stopping a container, in seconds (default: 1800 = 30 min)
CONTAINER_IDLE_TTL=1800