# Stage 1: Build user container image for per-user agent isolation
#
# Architecture:
#   main_server (host) ──► user container (this image, one per user)
#
# Each user gets an isolated container running their own Claude Agent SDK instance.
# The main_server bridges WebSocket connections to this container.
#
# Build:
#   docker build -t web-agent-user:latest -f Dockerfile.user .

FROM python:3.12-slim

WORKDIR /app

# Use Aliyun mirror for faster apt in China
RUN sed -i 's|http://deb.debian.org/debian|https://mirrors.aliyun.com/debian|g' /etc/apt/sources.list.d/debian.sources

# Install system deps for agent tools (git, curl, build-essential, nodejs for MCP servers)
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    build-essential \
    nodejs \
    npm \
    && rm -rf /var/lib/apt/lists/*

# Install uv as root
RUN pip install --no-cache-dir -i https://pypi.tuna.tsinghua.edu.cn/simple uv

# Create agent user and prepare /app for non-root usage
RUN useradd --create-home --uid 1000 agent && \
    chown -R agent:agent /app /home/agent

# Switch to agent — COPY and RUN commands inherit agent ownership
USER agent

# Install Python deps via uv (cached unless pyproject.toml/uv.lock change)
COPY pyproject.toml uv.lock ./
ENV UV_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
RUN uv sync --frozen --no-dev && \
    rm -rf $(uv cache dir)

# Copy source code
COPY src/ ./src/
COPY agent_server.py ./

# Switch back to root for entrypoint (UID/GID adaptation requires root)
USER root

# Copy container entrypoint
COPY entrypoint.sh /

ENV PYTHONUNBUFFERED=1 \
    HOME=/home/agent \
    WORKSPACE=/workspace \
    UV_FROZEN=true

EXPOSE 8000
# Don't set USER — entrypoint.sh runs as root to adapt agent UID/GID,
# then drops privileges with runuser before executing the CMD.
ENTRYPOINT ["/entrypoint.sh"]
CMD ["uv", "run", "uvicorn", "agent_server:app", "--host", "0.0.0.0", "--port", "8000"]
