# Stage 1: Build user container image for per-user agent isolation
#
# Architecture:
#   main_server (host) ──► user container (this image, one per user)
#
# Each user gets an isolated container running their own Claude Agent SDK instance.
# The main_server bridges WebSocket connections to this container.
#
# Build:
#   docker build -t web-agent-user:latest -f Dockerfile.user .

FROM python:3.12-slim

WORKDIR /app

# Install system deps for agent tools (git, curl, build-essential for pip packages)
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Create non-root agent user (uid 1000 matches host useradd convention)
RUN useradd --create-home --uid 1000 agent && \
    mkdir -p /workspace /home/agent/.claude && \
    chown -R agent:agent /workspace /home/agent /app

# Copy backend source (for hooks, utilities, agent server)
COPY pyproject.toml uv.lock ./
COPY src/ ./src/

# Install Python deps via uv
RUN pip install --no-cache-dir uv && \
    uv sync --frozen --no-dev && \
    chown -R agent:agent /app

# Copy agent server entry point
COPY agent_server.py ./

ENV PYTHONUNBUFFERED=1 \
    HOME=/home/agent

EXPOSE 8000
USER agent
CMD ["uv", "run", "uvicorn", "agent_server:app", "--host", "0.0.0.0", "--port", "8000"]
