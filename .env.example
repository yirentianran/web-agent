# ── Auth ──────────────────────────────────────────────────────────
#
# API key — one of:
#   ANTHROPIC_AUTH_TOKEN  (checked first)
#   ANTHROPIC_API_KEY     (fallback, undocumented; prefer AUTH_TOKEN)
#
# Per-user overrides: ANTHROPIC_AUTH_TOKEN_<USERID> (uppercase user ID)
# takes precedence over the global token.
#
# Direct Anthropic:   sk-ant-api03-...
# Bailian Coding Plan: sk-sp-...
ANTHROPIC_AUTH_TOKEN=sk-...

# Custom API endpoint. Omit for the default Anthropic endpoint.
# Bailian: https://coding.dashscope.aliyuncs.com/apps/anthropic
# ANTHROPIC_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic

# ── Model ──────────────────────────────────────────────────────────
#
# MODEL    — main agent conversations (no default; must be set)
#            DeepSeek: deepseek-chat / deepseek-v4-pro
#            Bailian:  qwen3.6-plus
#            Anthropic: claude-sonnet-4-6 / claude-opus-4-6
#
# FLASH_MODEL — lightweight tasks: title generation, instinct extraction,
#               skill feedback (default: falls back to MODEL)
#
# MODEL=deepseek-chat
# FLASH_MODEL=deepseek-chat

# ── Data ──────────────────────────────────────────────────────────

DATA_ROOT=./data
DATA_DB_PATH=./data/web-agent.db

# ── Agent ─────────────────────────────────────────────────────────

AGENT_TASK_TIMEOUT=300        # seconds (default: 300 = 5 min)
MAX_TURNS=200                 # max conversation turns per task
# MAX_PROMPT_LENGTH=32000     # max prompt length for continuation
# MAX_CONTINUATION_WINDOW=50  # max history window for continuation
# TOOL_RESULT_MAX_CHARS=500   # max chars per tool result in context
# MAX_BUFFER_SIZE=10485760    # SDK buffer size in bytes (default: 10 MB)
# MAX_UPLOAD_BYTES=209715200  # max upload file size in bytes (default: 200 MB)
# MAX_TOOL_OUTPUT_CHARS=8000  # max chars per tool output in logs

# ── Mode ──────────────────────────────────────────────────────────

# PROD=false                  # serve frontend static files from backend
# ENFORCE_AUTH=false          # require JWT auth for all endpoints

# ── Auth ──────────────────────────────────────────────────────────

# JWT signing secret. Defaults to a dev-only value — SET IN PRODUCTION.
# JWT_SECRET=change-me-in-production-at-least-32-chars

# ── Container ─────────────────────────────────────────────────────

# CONTAINER_MODE=false        # enable per-user Docker container isolation
# CONTAINER_IDLE_TTL=1800     # idle seconds before stopping container (30 min)

# Absolute path to data/ on the Docker HOST machine.
# Required for per-user container volume mounts to resolve correctly.
# Not needed when main_server runs directly on the host (no Docker).
# HOST_DATA_ROOT=/home/ubuntu/web-agent/data

# Container resource quotas (post-hoc monitoring)
# RESOURCE_MAX_CPU_PERCENT=100
# RESOURCE_MAX_MEMORY_MB=4096
# RESOURCE_MAX_DISK_MB=1024

# ── Sandbox ───────────────────────────────────────────────────────

# Code execution sandbox mode: "docker" or unset (default: disabled)
# SANDBOX_MODE=docker
# SANDBOX_IMAGE=python:3.12-slim
# SANDBOX_NETWORK=none        # network isolation (default: none)
# SANDBOX_CPU_QUOTA=50000     # CPU quota in microseconds (50% of one core)
# SANDBOX_CPU_PERIOD=100000   # CPU period in microseconds
# SANDBOX_MEM_LIMIT=1g        # memory limit

# ── Logging ───────────────────────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
# Invalid values fall back to INFO.
LOG_LEVEL=INFO

# Log directory (default: ./logs when running on host)
# LOG_DIR=./logs

# Per-component log directories (defaults shown, relative to DATA_ROOT)
# APP_LOG_DIR=/data/logs/app
# AGENT_LOG_DIR=/data/logs/agent
# CONTAINER_LOG_DIR=/data/logs/container
# AUDIT_LOG_DIR=/data/logs/audit

# Retention in days
# APP_LOG_RETENTION_DAYS=30
# AGENT_LOG_RETENTION_DAYS=90
# CONTAINER_LOG_RETENTION_DAYS=7
# AUDIT_LOG_RETENTION_DAYS=1095
