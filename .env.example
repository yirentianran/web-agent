# Anthropic auth token (preferred for custom base URLs)
# For direct Anthropic API (default endpoint): use ANTHROPIC_API_KEY=sk-ant-api03-...
# For Alibaba Cloud Bailian Coding Plan: ANTHROPIC_AUTH_TOKEN=sk-sp-...
# Note: ANTHROPIC_AUTH_TOKEN takes priority. Do NOT set both simultaneously.
ANTHROPIC_AUTH_TOKEN=sk-...

# Anthropic base URL (optional)
# Omit this to use the default Anthropic API endpoint.
# For Alibaba Cloud Bailian: https://coding.dashscope.aliyuncs.com/apps/anthropic
# ANTHROPIC_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic

# Model name (default: claude-sonnet-4-6)
# For Alibaba Cloud Bailian: qwen3.6-plus
# MODEL=qwen3.6-plus

# ── Data ──────────────────────────────────────────────────────────

# Data root directory
DATA_ROOT=./data

# SQLite database path (leave empty for file-based storage)
DATA_DB_PATH=./data/web-agent.db

# ── Agent ─────────────────────────────────────────────────────────

# Agent task timeout in seconds (default: 300)
AGENT_TASK_TIMEOUT=18000

# Maximum conversation turns per task (default: 200)
MAX_TURNS=500

# Maximum prompt length for continuation (default: 32000)
# MAX_PROMPT_LENGTH=32000

# Maximum continuation history window (default: 50)
# MAX_CONTINUATION_WINDOW=50

# Max characters per tool result in context (default: 500)
# TOOL_RESULT_MAX_CHARS=500

# SDK max buffer size in bytes (default: 10MB)
# MAX_BUFFER_SIZE=10485760

# Maximum upload file size in bytes (default: 200MB)
# MAX_UPLOAD_BYTES=209715200

# ── Mode ──────────────────────────────────────────────────────────

# Production mode — enables frontend static file serving (default: false)
# PROD=false

# Enforce JWT authentication (default: false)
# ENFORCE_AUTH=false

# ── Auth ──────────────────────────────────────────────────────────

# JWT signing secret (default: dev-secret-... — CHANGE IN PRODUCTION)
# JWT_SECRET=your-secret-at-least-32-chars

# Per-user API key override — set to give each user their own API key
# Format: ANTHROPIC_API_KEY = global fallback when per-user key absent
# Format: ANTHROPIC_API_KEY_<USER_ID_UPPER> = per-user key
# ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Container ─────────────────────────────────────────────────────

# Enable per-user Docker container isolation (default: false)
# CONTAINER_MODE=false

# Idle timeout before stopping a container, in seconds (default: 1800 = 30 min)
# CONTAINER_IDLE_TTL=1800

# Container resource quotas (post-hoc monitoring, default: no limit)
# RESOURCE_MAX_CPU_PERCENT=100
# RESOURCE_MAX_MEMORY_MB=4096
# RESOURCE_MAX_DISK_MB=1024

# ── Logging ───────────────────────────────────────────────────────

# Log level: debug, info, warning, error (default: info)
LOG_LEVEL=info

# Log directory overrides (defaults shown)
# APP_LOG_DIR=/data/logs/app
# AGENT_LOG_DIR=/data/logs/agent
# CONTAINER_LOG_DIR=/data/logs/container
# AUDIT_LOG_DIR=/data/logs/audit

# Log retention in days
# APP_LOG_RETENTION_DAYS=30
# AGENT_LOG_RETENTION_DAYS=90
# CONTAINER_LOG_RETENTION_DAYS=7
# AUDIT_LOG_RETENTION_DAYS=1095
