# Anthropic auth token (preferred for custom base URLs)
# For direct Anthropic API (default endpoint): use ANTHROPIC_API_KEY=sk-ant-api03-...
# For Alibaba Cloud Bailian Coding Plan: ANTHROPIC_AUTH_TOKEN=sk-sp-...
# Note: ANTHROPIC_AUTH_TOKEN takes priority. Do NOT set both simultaneously.
ANTHROPIC_AUTH_TOKEN=sk-...

# Anthropic base URL (optional)
# Omit this to use the default Anthropic API endpoint.
# For Alibaba Cloud Bailian: https://coding.dashscope.aliyuncs.com/apps/anthropic
# ANTHROPIC_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic

# Model name (default: claude-sonnet-4-6)
# For Alibaba Cloud Bailian: qwen3.6-plus
# MODEL=qwen3.6-plus

# Data root directory
DATA_ROOT=./data

# SQLite database path (leave empty for file-based storage)
DATA_DB_PATH=./data/web-agent.db

# Agent task limits (seconds / turns)
AGENT_TASK_TIMEOUT=18000
MAX_TURNS=500

# Logging
LOG_LEVEL=info
